name: ubuntu-vm
transport: ssh
tags: [linux, vm]
capabilities:
  shell: true
  sync: true
  install: true
ssh:
  host: 10.0.0.42
  user: ubuntu
  port: "22"
  identity: ~/.ssh/id_ed25519
  strictHost: "accept-new"  # 'yes' | 'no' | 'accept-new'
  # knownHosts: ~/.ssh/known_hosts
  # dest: /home/ubuntu/app  # default sync destination
