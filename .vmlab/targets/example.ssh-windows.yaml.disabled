name: win11
transport: ssh-windows
tags: [windows, vm]
capabilities:
  shell: true
  sync: true
  install: true
  screenshot: true
ssh:
  host: 10.0.0.99
  user: Administrator
  port: "22"
  identity: ~/.ssh/id_ed25519
  shell: pwsh        # pwsh | powershell | cmd | none
  strictHost: "accept-new"
  # dest: C:/vmlab   # default sync destination on the Windows guest
